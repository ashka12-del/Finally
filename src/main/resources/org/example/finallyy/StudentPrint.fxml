<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20.0" style="-fx-background-color: radial-gradient(focus-angle 45deg, focus-distance 50%, center 20% 20%, radius 80%, #341b71 0%, #160349 40%, #000000 100%); -fx-padding: 30;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.finallyy.PrintReqController">
    <children>
        <Button onAction="#goBackToDashboard" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-background-radius: 10; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-radius: 10;" text="⬅ Back to Dashboard" />

        <VBox alignment="CENTER" maxWidth="Infinity">
            <Text fill="WHITE" text="Smart Printing System" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-effect: dropshadow(gaussian, #ff00ff, 15, 0.5, 0, 0);">
                <font>
                    <Font name="System Bold" size="42.0" />
                </font>
            </Text>
        </VBox>

        <HBox spacing="30.0">
            <children>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Select Printer" textFill="WHITE" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="printerSelection" onAction="#updateQueueDisplay" prefHeight="40.0" prefWidth="350.0" promptText="Choose Printer" style="-fx-background-color: rgba(0,0,0,0.4); -fx-text-fill: white;" />
                </VBox>

                <VBox alignment="CENTER" prefHeight="70.0" prefWidth="250.0" style="-fx-background-color: rgba(0,0,0,0.5); -fx-border-color: #df85ff; -fx-border-radius: 15; -fx-border-width: 2;">
                    <children>
                        <Label fx:id="queueDisplayLabel" text="Queue: 0" textFill="#f3f6ff">
                            <font><Font name="System Bold" size="20.0" /></font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <VBox fx:id="uploadArea" alignment="CENTER" onMouseClicked="#handleFileUpload" prefHeight="100.0" style="-fx-background-color: rgba(255,255,255,0.08); -fx-border-color: #ff007f; -fx-border-style: dashed; -fx-border-radius: 15; -fx-cursor: hand;">
            <children>
                <Text fx:id="fileNameLabel" fill="#f0f0f0" text="Click to upload your PDF file">
                    <font><Font name="System Italic" size="14.0" /></font>
                </Text>
            </children>
        </VBox>

        <VBox alignment="CENTER" maxWidth="Infinity">
            <Text fill="WHITE" text="Smart Printing Configuration" strokeType="OUTSIDE" strokeWidth="0.0">
                <font>
                    <Font name="System Bold" size="30.0" />
                </font>
            </Text>
        </VBox>

        <GridPane hgap="20.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" prefWidth="350.0" />
                <ColumnConstraints hgrow="SOMETIMES" prefWidth="350.0" />
            </columnConstraints>
            <children>
                <VBox spacing="5">
                    <Label text="Page Range" textFill="WHITE" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="pageRangeBox" prefHeight="35.0" prefWidth="350.0" style="-fx-background-color: rgba(255,255,255,0.1);" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1">
                    <Label text="Color Mode" textFill="WHITE" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="colorModeBox" prefHeight="35.0" prefWidth="350.0" style="-fx-background-color: rgba(255,255,255,0.1);" />
                </VBox>
                <VBox spacing="5" GridPane.rowIndex="1">
                    <Label text="Copies" textFill="WHITE" style="-fx-font-weight: bold;" />
                    <Spinner fx:id="copiesSpinner" prefHeight="35.0" prefWidth="350.0" style="-fx-background-color: rgba(255,255,255,0.1);" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Paper Size" textFill="WHITE" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="paperSizeBox" prefHeight="35.0" prefWidth="350.0" style="-fx-background-color: rgba(255,255,255,0.1);" />
                </VBox>
            </children>
        </GridPane>

        <HBox spacing="20.0">
            <children>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Pickup Date" textFill="WHITE" style="-fx-font-weight: bold;" />
                    <DatePicker fx:id="pickupDatePicker" prefHeight="35.0" prefWidth="350.0" />
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Pickup Time" textFill="WHITE" style="-fx-font-weight: bold;" />
                    <ComboBox fx:id="pickupTimeBox" prefHeight="35.0" prefWidth="350.0" style="-fx-background-color: rgba(255,255,255,0.1);" />
                </VBox>
            </children>
        </HBox>

        <VBox alignment="CENTER">
            <Button onAction="#generateToken" prefHeight="55.0" prefWidth="320.0" style="-fx-background-color: linear-gradient(to right, #d14f90, #8A2BE2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-cursor: hand; -fx-font-size: 18; -fx-effect: dropshadow(gaussian, #ff007f, 15, 0.4, 0, 0);" text="Generate Print Token" />
        </VBox>
    </children>
</VBox>